<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Student Registration Form</title>

<style>
    *{
        margin:0;
        padding:0;
        box-sizing:border-box;
        font-family:Arial, sans-serif;
    }

    body{
        background:linear-gradient(135deg,#4facfe,#00f2fe);
        display:flex;
        justify-content:center;
        align-items:center;
        min-height:100vh;
    }

    .container{
        background:#fff;
        width:90%;
        max-width:500px;
        padding:25px;
        border-radius:10px;
        box-shadow:0 5px 15px rgba(0,0,0,0.3);
    }

    h2{
        text-align:center;
        margin-bottom:20px;
        color:#333;
    }

    .form-group{
        margin-bottom:15px;
    }

    label{
        display:block;
        margin-bottom:5px;
        font-weight:bold;
    }

    input{
        width:100%;
        padding:10px;
        border:1px solid #ccc;
        border-radius:5px;
        font-size:16px;
    }

    input:focus{
        border-color:#4facfe;
        outline:none;
    }

    .btn{
        width:100%;
        padding:12px;
        background:#4facfe;
        color:white;
        border:none;
        border-radius:5px;
        font-size:18px;
        cursor:pointer;
    }

    .btn:hover{
        background:#0077ff;
    }

    .error{
        color:red;
        font-size:14px;
    }

    @media(max-width:600px){
        .container{
            padding:20px;
        }
    }
</style>

</head>
<body>

<div class="container">
    <h2>Student Registration Form</h2>

    <form id="studentForm">

        <div class="form-group">
            <label>Student Name</label>
            <input type="text" id="name" value="M Lokesh">
            <div class="error" id="nameError"></div>
        </div>

        <div class="form-group">
            <label>10th Class Marks</label>
            <input type="number" id="marks" value="520">
            <div class="error" id="marksError"></div>
        </div>

        <div class="form-group">
            <label>School Name</label>
            <input type="text" id="school" value="Surya High School, Srikakulam">
            <div class="error" id="schoolError"></div>
        </div>

        <div class="form-group">
            <label>College Name</label>
            <input type="text" id="college" value="ANITS Engineering College">
            <div class="error" id="collegeError"></div>
        </div>

        <div class="form-group">
            <label>Email</label>
            <input type="email" id="email" value="mudadlalokesh.24.it@anits.edu.in">
            <div class="error" id="emailError"></div>
        </div>

        <button type="submit" class="btn">Register</button>

    </form>
</div>

<script>

document.getElementById("studentForm").addEventListener("submit", function(e){

    e.preventDefault();

    let valid = true;

    document.getElementById("nameError").innerHTML="";
    document.getElementById("marksError").innerHTML="";
    document.getElementById("schoolError").innerHTML="";
    document.getElementById("collegeError").innerHTML="";
    document.getElementById("emailError").innerHTML="";

    let name = document.getElementById("name").value.trim();
    let marks = document.getElementById("marks").value.trim();
    let school = document.getElementById("school").value.trim();
    let college = document.getElementById("college").value.trim();
    let email = document.getElementById("email").value.trim();

    if(name==""){
        document.getElementById("nameError").innerHTML="Please enter your name";
        valid=false;
    }

    if(marks=="" || marks<0 || marks>600){
        document.getElementById("marksError").innerHTML="Marks should be between 0 and 600";
        valid=false;
    }

    if(school==""){
        document.getElementById("schoolError").innerHTML="Please enter school name";
        valid=false;
    }

    if(college==""){
        document.getElementById("collegeError").innerHTML="Please enter college name";
        valid=false;
    }

    let emailPattern=/^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    if(!emailPattern.test(email)){
        document.getElementById("emailError").innerHTML="Enter a valid email";
        valid=false;
    }

    if(valid){
        alert("Student Registration Successful!");
        document.getElementById("studentForm").reset();
    }

});

</script>

</body>
</html>
